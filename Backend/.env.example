PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=imperial_guard

# Seguridad y auditoría
AUDIT_ENABLED=true
AUDIT_LOG_FILE=./logs/audit.log

# Confirmación de acciones críticas
CRITICAL_CONFIRMATION_ENABLED=true
CRITICAL_CONFIRMATION_MODE=header
CRITICAL_CONFIRMATION_VALUE=CONFIRM
CRITICAL_CONFIRMATION_TTL_SECONDS=300

# Backups automáticos
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPTION_ENABLED=false
